# 嵌入服务 Docker 部署变量示例（Linux GPU 服务器）
# 复制为 Embedding/docker/.env，docker compose 会自动读取。
#
#   cp .env.docker.example .env
#
# 自包含布局（与 LLM/OCR/合同业务各自独立）：
#   ~/app/Embedding/
#     docker/   <- 本目录（compose 在这里跑）
#     models/   <- GGUF 放这里
# 此时 MODELS_DIR 用相对路径 ../models 即可（相对 compose 文件所在目录解析）。

# 宿主机模型目录，会被只读挂载到容器内 /models。放别处就写绝对路径。
MODELS_DIR=../models

# 相对 /models 的嵌入模型文件路径（容器内路径 = /models/<此值>）。
EMBED_MODEL_FILE=Qwen3-Embedding-0.6B/Qwen3-Embedding-0.6B-Q8_0.gguf

# 池化方式：Qwen3-Embedding 用 last；换 bge-m3 改 cls。
EMBED_POOLING=last

# 暴露到宿主机的端口（容器内固定 8081）。Qwen 在 8080，勿撞。
EMBED_SERVER_PORT=8081

# 用哪张 GPU。Qwen 在 0，嵌入默认吃备用的 1（零争抢）。
EMBED_GPU_DEVICE_ID=1

# 上卡层数。0.6B 全量 offload，99 = 全上 GPU；显存极紧可设 0 走 CPU（此规模 CPU 也够）。
N_GPU_LAYERS=99

# 上下文长度。合同摘要/查询句很短，2048 绰绰有余（嵌长文本再按需调大）。
CONTEXT_SIZE=2048

# 批大小：-ub 直接决定计算缓冲显存。0.6B 配 8192 会虚占 ~6.5GB；短摘要场景 2048 足够、显存大降。
# 注意：-ub 须 ≥ 单条最长 token 数（嵌入是非因果、整条一次前向）。
BATCH_SIZE=2048
UBATCH_SIZE=2048
